rules_version = '2';

// Deploy with: firebase deploy --only firestore:rules
// Each signed-in user may only read/write their own application data.
// Audit logs are server-only (written via the Admin SDK from API routes)
// and are intentionally not readable or writable by any client.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid}/{collection}/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /auditLogs/{logId} {
      allow read, write: if false;
    }
  }
}
