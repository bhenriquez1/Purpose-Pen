# Firebase (client-side, used for Auth + Firestore persistence)
# Required for real persistence. If unset, the Letter of Recommendation
# Suite falls back to localStorage automatically.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Anthropic (server-side, used for AI letter drafting, request emails,
# letter analysis, and voice match scoring)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
