# Firebase (client-side, used for Auth + Firestore persistence)
# Required. Purpose Pen requires Firebase Authentication to be configured —
# there is no public or anonymous access. Without these set, the app shows
# a "Setup Required" screen instead of any dashboard content.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Optional. Enables Firebase Analytics in the browser only; safe to leave unset.
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase Admin (server-only, used to verify ID tokens and write tamper-proof
# audit logs). Generate a service account key from Firebase Console >
# Project Settings > Service Accounts.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Beta access control (server-only). Comma-separated email addresses.
# Accounts that sign up but are not listed here see "This beta is
# currently invite-only." Owner emails get full admin/owner access and do
# not also need to be listed in ALLOWED_EMAILS.
ALLOWED_EMAILS=
OWNER_EMAILS=

# Anthropic (server-side, used for AI letter drafting, request emails,
# letter analysis, and voice match scoring)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Site-wide password gate (edge middleware, optional). When SITE_PASSWORD is
# set, every request — including API routes — must pass HTTP Basic Auth with
# this username/password before reaching the app at all. This is a second,
# independent layer in front of the Firebase auth wall, recommended for any
# publicly reachable deployment (e.g. staging) as defense-in-depth. Leave
# unset to disable (the Firebase auth wall still applies).
SITE_PASSWORD_USERNAME=purpose-pen
SITE_PASSWORD=Amberly2022

# Signs the session cookie that proxy.ts (the edge route guard) checks for
# protected pages and /api/*. Required for real auth enforcement to work —
# without it, protected routes fail closed (deny) for everyone except dev
# bypass. Generate with: openssl rand -hex 32
SESSION_SECRET=

# Temporary escape hatch — set to "true" to preview the app UI without
# configuring Firebase. Bypasses the auth wall (proxy.ts, requireAuthedUser,
# and the client AuthGate) and grants owner access using a mock dev user;
# data is stored in localStorage (the existing no-Firebase fallback).
# Blocked in a production build (NODE_ENV=="production", which is what
# `next start` on Render always sets) unless ALLOW_PRODUCTION_DEV_BYPASS is
# also set — see below. AI features still require ANTHROPIC_API_KEY and
# will not work without it.
NEXT_PUBLIC_DEV_BYPASS_AUTH=

# Server-only. Must be set alongside NEXT_PUBLIC_DEV_BYPASS_AUTH to let the
# bypass take effect in a production build (e.g. on Render). Only ever set
# this on a deployment that also has SITE_PASSWORD set, since the bypass
# disables all real authentication.
ALLOW_PRODUCTION_DEV_BYPASS=
